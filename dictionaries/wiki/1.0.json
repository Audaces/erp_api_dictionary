  "product": {
    "endpoint" : "http://SERVIDOR:PORTA/api/wiki_v2/produto_post",
    "method" : "POST",
    "send_as_json" : true,
    "bodyparam": {},
    "queryparam":
    {
      "audaces": 1
    },
    "erp_search_id" : "FchProdId",
    "header" :
    {
      "Token" : "Bearer {token}"
    },
    "input": {
      "keys": {
        "ProdReferencia": "variants.0.custom_fields.ref.value",
        "ProdDescricao": "variants.0.description",
        "ProdSituacao": "variants.0.custom_fields.ProdSituacao.value",
        "ProdTipo": "variants.0.custom_fields.ProdTipo.value",
        "ProdGradeId": "variants.0.custom_fields.Grade.value"
      },
      "fields_to_extract_id": ["ProdGradeId"],
      "integer_fields": ["ProdGradeId"],
      "custom_keys": {
        "ListaCores": {
          "source": "variants",
          "deduplicate": true,
          "id_field": "CorId",
          "fields": {
            "CorId": {
              "path": "custom_fields.Cor.value",
              "split": "id - name"
            },
            "CorDescricao": {
              "path": "custom_fields.Cor.value",
              "split": "id - name"
            }
          },
          "field_transforms": {
            "extract_id_from_split": ["CorId"],
            "extract_name_from_split": ["CorDescricao"]
          }
        }
      }
    },
    "output" :
    {
      "result_list_key" : "",
      "response_wrapper": "retorno",
      "keys" :
      {
        "uid": "ProdId",
        "ProdReferencia": "variants.0.custom_fields.ref.value",
        "ProdDescricao": "variants.0.description",
        "ProdSituacao":"variants.0.custom_fields.ProdSituacao.value",
        "ProdTipo":"variants.0.custom_fields.ProdTipo.value"
      },
      "custom_keys" :
      {
        "ListaCores":
        [
          {
            "CorId": "variants.custom_fields.Cor.value",
            "CorDescricao": "variants.custom_fields.Cor.value"
          }
        ]
      }
    }
  },
  "garment" : {
    "endpoint" : "http://SERVIDOR:PORTA/api/wiki_v2/ficha_tecnica_post",
    "method" : "POST",
    "send_as_json" : true,
    "bodyparam": {},
    "queryparam":
    {
      "audaces": 1
    },
    "erp_search_id" : "FchProdId",
    "header" :
    {
      "Token" : "Bearer {token}"
    },
    "input": {
      "keys": {
        "FchProdId": "variants.0.custom_fields.ref.value",
        "FchData": "last_modified",
        "FchDescricao": "variants.0.description"
      },
      "default_values": {
        "FchAprovado": 1,
        "FchAtual": 1
      },
      "custom_keys": {
        "Materiais": {
          "source": "variants.materials",
          "group_by": "uid",
          "id_field": "MatId",
          "fields": {
            "MatId": "uid",
            "Ficha_Cor": {
              "MatCorId": "color",
              "ProdCorId": "custom_fields.Cor.value"
            },
            "Ficha_Grade": {
              "ProdTam": "custom_fields.Tamanho.value",
              "MatTam": "custom_fields.size.value",
              "Qtd": "amount"
            }
          },
          "field_transforms": {
            "extract_id_from_split": ["ProdCorId"]
          }
        },
        "Servicos": {
          "source": "variants.activities",
          "deduplicate": true,
          "id_field": "SerId",
          "fields": {
            "SerId": "uid",
            "SerVlr": "cost",
            "TempoMedioHrs": "time"
          }
        }
      }
    },
    "output" :
    {
      "result_list_key" : "",
      "uid_field": "FchId",
      "response_wrapper": "retorno",
      "keys" :
      {
        "uid": "FchId",
        "FchId": "uid",
        "FchProdId": "variants.0.custom_fields.ref.value",
        "FchData":"last_modified",
        "FchDescricao":"variants.0.description"
      },
      "custom_keys": {
        "Materiais": [
          {
            "MatId": "variants.materials.uid",
            "MatCorId": "variants.materials.color",
            "ProdCorId": "variants.custom_fields.Cor.value",
            "ProdTam": "variants.custom_fields.Tamanho.value",
            "MatTam": "variants.materials.custom_fields.size.value",
            "Qtd": "variants.materials.amount",
            "VlrUnit": "variants.materials.cost"
          }
        ],
        "Servicos": [
          {
            "SerId": "variants.activities.uid",
            "SerVlr": "variants.activities.cost",
            "TempoMedioHrs": "variants.activities.time"
          }
        ]
      },
      "erp_format": {}
    }
  },
