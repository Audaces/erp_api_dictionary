    "product" : {
        "endpoint" : "http://SERVIDOR:PORTA/Produto",
        "method" : "POST",
        "send_as_json" : true,
        "input_id_field" : "codigo",
        "queryparam" : {},
        "bodyparam" : {},
        "erp_search_id" : "codigo",
        "header" : {
            "Token" : "{erp_user}"
        },
        "input" : {
            "payload_type" : "array",
            "keys" : {
                "descricao" : "variants.0.description",
                "grupo"     : "variants.0.custom_fields.grupo.value",
                "colecao"   : "variants.0.custom_fields.Colecoes.value",
                "faixa"     : "variants.0.custom_fields.faixa.value",
                "familia"   : "variants.0.custom_fields.familia.value",
                "etiqueta"  : "variants.0.custom_fields.etiqueta.value",
                "marca"     : "variants.0.custom_fields.marca.value",
                "linha"     : "variants.0.custom_fields.linha.value",
                "status"    : "variants.0.custom_fields.status.value",
                "unidade"   : "variants.0.custom_fields.unidade.value",
                "codfis"    : "variants.0.custom_fields.codfis.value",
                "codsped"   : "variants.0.custom_fields.codsped.value",
                "estilista" : "variants.0.custom_fields.estilista.value",
                "modelista" : "variants.0.custom_fields.modelista.value"
            },
            "field_transforms" : {
                "extract_id_from_split" : ["grupo", "colecao", "faixa", "familia", "etiqueta", "marca", "linha"],
                "extract_name_from_split" : ["status"]
            },
            "custom_keys" : {
                "cor" : {
                    "source" : "variants",
                    "deduplicate" : true,
                    "id_field" : "cor_code",
                    "fields" : {
                        "cor_code" : {
                            "path" : "custom_fields.Cor.value",
                            "split" : "id - name"
                        }
                    },
                    "field_transforms" : {
                        "extract_id_from_split" : ["cor_code"]
                    },
                    "flatten_to_values" : "cor_code"
                }
            }
        },
        "output" : {
            "result_list_key" : "",
            "keys" : {
                "uid" : "produto"
            }
        }
    },
    "garment" : {
        "endpoint" : "http://SERVIDOR:PORTA/FichaTecnicaProduto",
        "method" : "POST",
        "send_as_json" : true,
        "bodyparam" : {},
        "queryparam" : {
            "data" : "01/01/2020"
        },
        "erp_search_id" : "codigo",
        "header" : {
            "Token" : "{erp_user}"
        },
        "input" : {
            "payload_type" : "array",
            "root_custom_key" : "insumos",
            "strip_prefix_fields" : ["insumo"],
            "custom_keys" : {
                "insumos" : {
                    "source" : "variants.materials",
                    "group_by" : ["uid", "variants.custom_fields.Tamanho.value", "custom_fields.setor.value", "custom_fields.aplicacao.value", "color", "amount"],
                    "fields" : {
                        "insumo" : "uid",
                        "consumo" : "amount",
                        "aplicacao" : {
                            "path" : "custom_fields.aplicacao.value",
                            "split" : "id - name",
                            "default_value" : ""
                        },
                        "faixa" : {
                            "path" : "variants.custom_fields.Tamanho.value",
                            "split" : "id - name",
                            "default_value" : ""
                        },
                        "setor" : {
                            "path" : "custom_fields.setor.value",
                            "split" : "id - name",
                            "default_value" : ""
                        },
                        "cor" : {
                            "cor" : {
                                "path" : "variants.custom_fields.Cor.value",
                                "split" : "id - name"
                            },
                            "cor_i" : {
                                "path" : "color",
                                "split" : "id - name"
                            }
                        }
                    },
                    "default_values" : {
                        "tipo" : "M",
                        "preco" : "S"
                    },
                    "field_transforms" : {
                        "extract_id_from_split" : ["aplicacao", "faixa", "setor", "cor", "cor_i"]
                    }
                }
            }
        },
        "output" : {
            "result_list_key" : "",
            "keys" : {
                "cor"      : "[variants.Cor]",
                "codigo"   : "uid",

                "colecao"  : "variants.0.custom_fields.Colecoes.value",
                "faixa"    : "variants.0.custom_fields.faixa.value",
                "etiqueta" : "variants.0.custom_fields.etiqueta.value",
                "familia"  : "variants.0.custom_fields.familia.value",
                "grupo"    : "variants.0.custom_fields.grupo.value",
                "linha"    : "variants.0.custom_fields.linha.value",
                "marca"    : "variants.0.custom_fields.marca.value",

                "descricao" : "variants.0.description",
                "unidade"   : "variants.0.unidade",
                "estilista" : "variants.0.estilista",
                "modelista" : "variants.0.modelista",
                "codfis"    : "variants.0.codfis",
                "codsped"   : "variants.0.codsped",
                "status"    : "variants.0.status"
            },
            "custom_keys" : {
                "services": [
                    {
                        "serviceCode": "variants.activities.uid",
                        "quantity": "variants.activities.time",
                        "value": "variants.activities.total"
                    }
                ],
                "rawMaterials": [
                    {
                        "insumo": "variants.materials.uid",
                        "consumo":"SUM variants.materials.amount"
                    }
                ]
            },
            "erp_format" : {
                "codigo": "uid",
                "insumo": "productCode",
                "consumo": "quantity",
                "preco": "S",
                "tipo": "M",
                "cor": [
                    {
                        "cor": "LN0000",
                        "cor_i": "0"
                    }
                ]
            }
        }
    },
    "operation_post" : {
        "endpoint" : "http://SERVIDOR:PORTA/Processo",
