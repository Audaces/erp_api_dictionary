                        "tempo"     : "time",
                        "custo"     : "total",
                        "maquina"   : "machine",
                        "perc"      : "custom_fields.percentual_dif.value",
                        "ordem"     : "custom_fields.ordem.value"
                    },
                    "default_values" : {}
                }
            }
        },
        "output" : {
            "result_list_key" : "",
